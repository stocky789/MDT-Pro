<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ReportDocFieldFillColor">#FDEBD0</Color>
    <SolidColorBrush x:Key="ReportDocFieldFill" Color="{StaticResource ReportDocFieldFillColor}" />
    <SolidColorBrush x:Key="ReportDocAuthBarBrush" Color="#B8D4E8" />
    <SolidColorBrush x:Key="ReportDocPaperBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ReportDocInkBrush" Color="#FF000000" />

    <Style x:Key="ReportDocLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ReportDocSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource ReportDocLabel}">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,10,0,6" />
    </Style>

    <Style x:Key="ReportDocTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{StaticResource ReportDocFieldFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
    </Style>

    <!-- Selected report DataGrid cells inherit Cad foreground (light); force dark type on light combo fields. -->
    <Style x:Key="ReportDocComboItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="Padding" Value="6,4" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#B8D4E8" />
                <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#7EB8E0" />
                <Setter Property="Foreground" Value="#FF000000" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ReportDocCombo" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Background" Value="{StaticResource ReportDocFieldFill}" />
        <Setter Property="BorderBrush" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource ReportDocInkBrush}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ReportDocComboItem}" />
        <Style.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource ReportDocInkBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource ReportDocInkBrush}" />
            </Style>
        </Style.Resources>
    </Style>
</ResourceDictionary>
