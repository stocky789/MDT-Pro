<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- In-car / dispatch CAD-inspired dark theme (generic; not a vendor copy). -->
    <Color x:Key="CadBgColor">#FF0A0C10</Color>
    <Color x:Key="CadPanelColor">#FF12151C</Color>
    <Color x:Key="CadElevatedColor">#FF1A1F2A</Color>
    <Color x:Key="CadBorderColor">#FF2D3548</Color>
    <Color x:Key="CadTextColor">#FFE8ECF3</Color>
    <Color x:Key="CadMutedColor">#FF8B95A8</Color>
    <Color x:Key="CadAccentColor">#FF4A9EFF</Color>
    <Color x:Key="CadUrgentColor">#FFFF4D4D</Color>
    <Color x:Key="CadStatusBarColor">#FF07080C</Color>

    <SolidColorBrush x:Key="CadBg" Color="{StaticResource CadBgColor}" />
    <SolidColorBrush x:Key="CadPanel" Color="{StaticResource CadPanelColor}" />
    <SolidColorBrush x:Key="CadElevated" Color="{StaticResource CadElevatedColor}" />
    <SolidColorBrush x:Key="CadBorder" Color="{StaticResource CadBorderColor}" />
    <SolidColorBrush x:Key="CadText" Color="{StaticResource CadTextColor}" />
    <SolidColorBrush x:Key="CadMuted" Color="{StaticResource CadMutedColor}" />
    <SolidColorBrush x:Key="CadAccent" Color="{StaticResource CadAccentColor}" />
    <SolidColorBrush x:Key="CadUrgent" Color="{StaticResource CadUrgentColor}" />
    <SolidColorBrush x:Key="CadStatusBar" Color="{StaticResource CadStatusBarColor}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource CadBg}" />
        <Setter Property="Foreground" Value="{StaticResource CadText}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="CadTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource CadElevated}" />
        <Setter Property="Foreground" Value="{StaticResource CadText}" />
        <Setter Property="BorderBrush" Value="{StaticResource CadBorder}" />
        <Setter Property="CaretBrush" Value="{StaticResource CadAccent}" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style x:Key="CadButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CadElevated}" />
        <Setter Property="Foreground" Value="{StaticResource CadText}" />
        <Setter Property="BorderBrush" Value="{StaticResource CadBorder}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="CadAccentButton" TargetType="Button" BasedOn="{StaticResource CadButton}">
        <Setter Property="Background" Value="#FF1E3A5F" />
        <Setter Property="BorderBrush" Value="{StaticResource CadAccent}" />
    </Style>

    <Style x:Key="CadLabelMuted" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CadMuted}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CadListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource CadPanel}" />
        <Setter Property="Foreground" Value="{StaticResource CadText}" />
        <Setter Property="BorderBrush" Value="{StaticResource CadBorder}" />
    </Style>
</ResourceDictionary>
