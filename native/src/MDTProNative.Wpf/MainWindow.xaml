<Window x:Class="MDTProNative.Wpf.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="MDT Pro — MDC Terminal"

        Icon="{StaticResource MdtProLogoImage}"

        MinHeight="640" MinWidth="1100"

        Height="780" Width="1320"

        WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">

        <!-- CAD footer: dispatch-style status + link lamp -->

        <Border DockPanel.Dock="Bottom"

                Background="{StaticResource CadStatusBar}"

                BorderBrush="{StaticResource CadBorder}"

                BorderThickness="0,1,0,0"

                Padding="12,6">

            <Grid>

                <TextBlock x:Name="FooterSummaryText"

                           FontFamily="{StaticResource CadFontMono}"

                           FontSize="11"

                           Foreground="{StaticResource CadAccent}"

                           VerticalAlignment="Center"

                           Text="NO ACTIVE SESSION" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <TextBlock x:Name="ConnStateText"

                               FontFamily="{StaticResource CadFontCondensed}"

                               FontSize="11"

                               FontWeight="Bold"

                               Foreground="{StaticResource CadUrgent}"

                               VerticalAlignment="Center"

                               Margin="0,0,8,0"

                               Text="OFFLINE" />

                    <Ellipse x:Name="ConnLamp"

                             Width="10" Height="10"

                             VerticalAlignment="Center"

                             Fill="{StaticResource CadUrgent}"

                             Stroke="#FF5C2A22"

                             StrokeThickness="1">

                        <Ellipse.Effect>

                            <DropShadowEffect Color="#FFE74C3C" BlurRadius="8" ShadowDepth="0" Opacity="0.85" />

                        </Ellipse.Effect>

                    </Ellipse>

                </StackPanel>

            </Grid>

        </Border>



        <Grid Background="{StaticResource CadBg}">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto" />

                <RowDefinition Height="*" />

            </Grid.RowDefinitions>



            <!-- Top tab strip: + DASHBOARD + connected module tabs (one row, CAD reference) -->

            <Border Grid.Row="0"

                    Background="{StaticResource CadTabStripDeep}"

                    BorderBrush="{StaticResource CadBorder}"

                    BorderThickness="0,0,0,1"

                    Padding="8,6,8,0">

                <DockPanel LastChildFill="True" VerticalAlignment="Bottom">

                    <StackPanel DockPanel.Dock="Left"

                                Orientation="Horizontal"

                                VerticalAlignment="Bottom"

                                Margin="0,0,8,0">

                        <Image Width="32" Height="32"

                               Margin="0,0,10,2"

                               VerticalAlignment="Bottom"

                               Source="{StaticResource MdtProLogoImage}"

                               RenderOptions.BitmapScalingMode="HighQuality"

                               SnapsToDevicePixels="True" />

                        <Button x:Name="HomeModuleBtn"

                                Content="+ DASHBOARD"

                                Style="{StaticResource CadTabLeadButton}"

                                Click="HomeModuleBtn_OnClick"

                                ToolTip="Open Dashboard module" />

                        <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Margin="12,0,0,2">

                            <TextBlock Text="MDT PRO" FontFamily="{StaticResource CadFontCondensed}" FontSize="9" Foreground="#FF7A8A9E" />

                            <TextBlock x:Name="TerminalOperatorLabel"

                                       FontFamily="{StaticResource CadFontMono}"

                                       FontSize="11"

                                       Foreground="{StaticResource CadSubTabActiveText}"

                                       Text="—"

                                       TextTrimming="CharacterEllipsis"

                                       MaxWidth="180" />

                        </StackPanel>

                    </StackPanel>

                    <ListBox x:Name="NavList"

                             Background="Transparent"

                             BorderThickness="0"

                             ScrollViewer.HorizontalScrollBarVisibility="Auto"

                             ScrollViewer.VerticalScrollBarVisibility="Disabled"

                             VerticalAlignment="Bottom"

                             VerticalContentAlignment="Bottom"

                             SelectionChanged="NavList_OnSelectionChanged"

                             ItemContainerStyle="{StaticResource CadModuleTabListBoxItem}">

                        <ListBox.ItemsPanel>

                            <ItemsPanelTemplate>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />

                            </ItemsPanelTemplate>

                        </ListBox.ItemsPanel>

                        <ListBox.ItemTemplate>

                            <DataTemplate>

                                <TextBlock Text="{Binding Title}"

                                           FontFamily="{StaticResource CadFontCondensed}"

                                           FontSize="11" />

                            </DataTemplate>

                        </ListBox.ItemTemplate>

                    </ListBox>

                </DockPanel>

            </Border>



            <!-- Main CAD workspace: orange rail | content + log | related panel -->

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="168" />

                    <ColumnDefinition Width="*" MinWidth="320" />

                    <ColumnDefinition Width="272" />

                </Grid.ColumnDefinitions>



                <!-- Left: primary actions -->

                <Border Grid.Column="0"

                        Background="{StaticResource CadStatusBar}"

                        BorderBrush="{StaticResource CadBorder}"

                        BorderThickness="0,0,1,0"

                        Padding="8,10,8,10">

                    <DockPanel LastChildFill="True">

                        <TextBlock DockPanel.Dock="Top"

                                   Text="ACTIONS"

                                   Foreground="{StaticResource CadSubTabActiveText}"

                                   FontFamily="{StaticResource CadFontCondensed}"

                                   FontSize="11"

                                   FontWeight="Bold"

                                   Margin="2,0,0,10" />

                        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">

                            <TextBlock Text="REN#"

                                       Style="{StaticResource CadFieldLabel}"

                                       Margin="0,0,0,2" />

                            <Border Background="{StaticResource CadElevated}"

                                    BorderBrush="{StaticResource CadBorder}"

                                    BorderThickness="1"

                                    CornerRadius="3"

                                    Padding="8,6"

                                    Margin="0,0,0,10">

                                <TextBlock Text="—"

                                           FontFamily="{StaticResource CadFontMono}"

                                           FontSize="11"

                                           Foreground="{StaticResource CadMuted}"

                                           HorizontalAlignment="Center" />

                            </Border>

                        </StackPanel>

                        <StackPanel>

                            <Button x:Name="QuickPanicBtn"

                                    Content="PANIC"

                                    Style="{StaticResource CadPrimaryActionButton}"

                                    Click="QuickPanic_Click"

                                    Margin="0,0,0,6"

                                    ToolTip="Request panic backup" />

                            <Button x:Name="QuickBackupBtn"

                                    Content="BACKUP…"

                                    Style="{StaticResource CadPrimaryActionButton}"

                                    Click="QuickBackup_Click"

                                    Margin="0,0,0,6"

                                    ToolTip="Backup menu (matches web)" />

                            <Button x:Name="QuickAlprBtn"

                                    Content="CLEAR ALPR"

                                    Style="{StaticResource CadPrimaryActionButton}"

                                    Click="QuickAlpr_Click"

                                    Margin="0,0,0,6" />

                            <Button Content="NOTEPAD"

                                    Style="{StaticResource CadPrimaryActionButton}"

                                    Click="QuickNotepad_Click"

                                    Margin="0,0,0,6" />

                            <Button Content="DRUGS REF"

                                    Style="{StaticResource CadPrimaryActionButton}"

                                    Click="QuickNarcotics_Click"

                                    Margin="0,0,0,6"

                                    ToolTip="Narcotics field reference" />

                            <Border Height="1" Background="{StaticResource CadBorder}" Margin="0,4,0,12" />

                            <Button Content="OFFICER"

                                    Style="{StaticResource CadPrimaryActionButtonMuted}"

                                    Click="QuickOfficer_Click"

                                    Margin="0,0,0,6" />

                            <Button Content="SETTINGS"

                                    Style="{StaticResource CadPrimaryActionButtonMuted}"

                                    Click="QuickSettings_Click"

                                    ToolTip="Version + open config in browser" />

                        </StackPanel>

                    </DockPanel>

                </Border>



                <!-- Center: module + CAD message log -->

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="*" />

                        <RowDefinition Height="168" />

                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"

                            Background="{StaticResource CadBg}"

                            BorderBrush="{StaticResource CadBorder}"

                            BorderThickness="0,0,1,0">

                        <ContentControl x:Name="ContentHost" />

                    </Border>

                    <Border Grid.Row="1"

                            Background="{StaticResource CadPanel}"

                            BorderBrush="{StaticResource CadBorder}"

                            BorderThickness="0,1,1,0"

                            Padding="8,6">

                        <DockPanel LastChildFill="True">

                            <TextBlock DockPanel.Dock="Top"

                                       Text="CAD MESSAGE LOG"

                                       Style="{StaticResource CadPanelHeader}"

                                       Margin="0,0,0,6" />

                            <ListBox x:Name="MessageLog"

                                     Style="{StaticResource CadListBox}"

                                     FontFamily="{StaticResource CadFontMono}"

                                     FontSize="11"

                                     ItemContainerStyle="{StaticResource CadLogListBoxItem}" />

                        </DockPanel>

                    </Border>

                </Grid>



                <!-- Right: related / system (officer + link + situation) -->

                <Border Grid.Column="2"

                        Background="{StaticResource CadPanel}"

                        BorderBrush="{StaticResource CadBorder}"

                        BorderThickness="0,0,0,0"

                        Padding="10,10,10,10">

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                        <StackPanel>

                            <Border Background="#FF0A1018"

                                    BorderBrush="{StaticResource CadBorder}"

                                    BorderThickness="0,0,0,1"

                                    Padding="0,0,0,0"

                                    Margin="0,0,0,10">

                                <StackPanel Orientation="Horizontal">

                                    <Border Background="{StaticResource CadSubTabActiveBg}"

                                            CornerRadius="2,2,0,0"

                                            Padding="10,7"

                                            VerticalAlignment="Bottom">

                                        <TextBlock Text="RELATED DATA"

                                                   Foreground="{StaticResource CadSubTabActiveText}"

                                                   FontFamily="{StaticResource CadFontCondensed}"

                                                   FontSize="10"

                                                   FontWeight="Bold"

                                                   VerticalAlignment="Center" />

                                    </Border>

                                    <TextBlock Text="CAD LOG"

                                               Foreground="#FF7A8A9E"

                                               FontFamily="{StaticResource CadFontCondensed}"

                                               FontSize="10"

                                               FontWeight="Bold"

                                               Margin="14,0,0,0"

                                               VerticalAlignment="Center"

                                               Padding="0,7,0,7" />

                                    <TextBlock x:Name="RightRailActivityTab"

                                               Text="CALLOUTS (0)"

                                               Foreground="#FF7A8A9E"

                                               FontFamily="{StaticResource CadFontCondensed}"

                                               FontSize="10"

                                               FontWeight="Bold"

                                               Margin="14,0,0,0"

                                               VerticalAlignment="Center"

                                               Padding="0,7,0,7" />

                                </StackPanel>

                            </Border>



                            <TextBlock Text="ASSOCIATED OFFICER" Style="{StaticResource CadSectionTitle}" />

                            <Border Style="{StaticResource CadSectionBorder}" Padding="8,8" Margin="0,0,0,12">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="72" />

                                        <ColumnDefinition Width="*" MinWidth="120" />

                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>

                                        <RowDefinition Height="Auto" />

                                        <RowDefinition Height="Auto" />

                                        <RowDefinition Height="Auto" />

                                        <RowDefinition Height="Auto" />

                                        <RowDefinition Height="Auto" />

                                        <RowDefinition Height="Auto" />

                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="FIRST" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />

                                    <TextBlock x:Name="OfFirst" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="LAST" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />

                                    <TextBlock x:Name="OfLast" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="BADGE" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />

                                    <TextBlock x:Name="OfBadge" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RANK" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />

                                    <TextBlock x:Name="OfRank" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" TextWrapping="Wrap" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="CALL" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />

                                    <TextBlock x:Name="OfCall" Grid.Row="4" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" TextWrapping="Wrap" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="DEPT" Style="{StaticResource CadFieldLabel}" />

                                    <TextBlock x:Name="OfDept" Grid.Row="5" Grid.Column="1" Style="{StaticResource CadSidebarReadout}" Text="—" TextWrapping="Wrap" />

                                </Grid>

                            </Border>



                            <TextBlock Text="SYSTEM / LINK" Style="{StaticResource CadSectionTitle}" />

                            <Border Style="{StaticResource CadSectionBorder}" Padding="8,8" Margin="0,0,0,12">

                                <StackPanel>

                                    <TextBlock Text="HOST" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,2" />

                                    <TextBox x:Name="HostBox" Style="{StaticResource CadTextBox}" Text="127.0.0.1" Margin="0,0,0,8" />

                                    <TextBlock Text="PORT" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,2" />

                                    <TextBox x:Name="PortBox" Style="{StaticResource CadTextBox}" Text="9000" Margin="0,0,0,8" />

                                    <UniformGrid Columns="2" Margin="0,0,0,0">

                                        <Button x:Name="ConnectBtn" Content="CONNECT" Style="{StaticResource CadAccentButton}" Click="Connect_Click" Margin="0,0,4,0" Padding="10,6" />

                                        <Button x:Name="DisconnectBtn" Content="DISCONNECT" Style="{StaticResource CadButton}" Click="Disconnect_Click" IsEnabled="False" Margin="4,0,0,0" Padding="10,6" />

                                    </UniformGrid>

                                </StackPanel>

                            </Border>



                            <TextBlock Text="SITUATION" Style="{StaticResource CadSectionTitle}" />

                            <Border Style="{StaticResource CadSectionBorder}" Padding="8,8">

                                <StackPanel>

                                    <DockPanel Margin="0,0,0,6">

                                        <TextBlock DockPanel.Dock="Left" Text="TIME" Style="{StaticResource CadFieldLabel}" Width="72" />

                                        <TextBlock x:Name="StatusTime" Style="{StaticResource CadSidebarReadout}" Text="—" TextTrimming="CharacterEllipsis" />

                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,6">

                                        <TextBlock DockPanel.Dock="Left" Text="LOCATION" Style="{StaticResource CadFieldLabel}" Width="72" />

                                        <TextBlock x:Name="StatusLocation"

                                                   Style="{StaticResource CadSidebarReadout}"

                                                   Text="—"

                                                   TextTrimming="CharacterEllipsis"

                                                   TextWrapping="Wrap" />

                                    </DockPanel>

                                    <DockPanel Margin="0,0,0,6">

                                        <TextBlock DockPanel.Dock="Left" Text="UNIT" Style="{StaticResource CadFieldLabel}" Width="72" />

                                        <TextBlock x:Name="StatusUnit" Style="{StaticResource CadSidebarReadout}" Text="—" />

                                    </DockPanel>

                                    <DockPanel>

                                        <TextBlock DockPanel.Dock="Left" Text="CALLOUTS" Style="{StaticResource CadFieldLabel}" Width="72" />

                                        <TextBlock x:Name="StatusCallouts" Style="{StaticResource CadSidebarReadout}" Text="—" />

                                    </DockPanel>

                                </StackPanel>

                            </Border>

                        </StackPanel>

                    </ScrollViewer>

                </Border>

            </Grid>

        </Grid>

    </DockPanel>

</Window>


