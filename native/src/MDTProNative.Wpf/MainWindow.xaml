<Window x:Class="MDTProNative.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MDT Pro — Native CAD / MDC"
        MinHeight="640" MinWidth="1000"
        Height="760" Width="1280"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="{StaticResource CadStatusBar}" BorderBrush="{StaticResource CadBorder}" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Host" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" />
                <TextBox x:Name="HostBox" Grid.Column="1" Style="{StaticResource CadTextBox}" Text="127.0.0.1" VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="2" Text="Port" Style="{StaticResource CadLabelMuted}" Margin="12,0,8,0" />
                <TextBox x:Name="PortBox" Grid.Column="3" Style="{StaticResource CadTextBox}" Text="9000" VerticalContentAlignment="Center" />
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button x:Name="ConnectBtn" Content="Connect" Style="{StaticResource CadAccentButton}" Click="Connect_Click" Margin="0,0,8,0" />
                    <Button x:Name="DisconnectBtn" Content="Disconnect" Style="{StaticResource CadButton}" Click="Disconnect_Click" IsEnabled="False" />
                </StackPanel>
                <TextBlock x:Name="ConnStateText" Grid.Column="6" VerticalAlignment="Center" Foreground="{StaticResource CadUrgent}" FontWeight="SemiBold" Text="OFFLINE" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="TIME" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" FontSize="11" />
                    <TextBlock x:Name="StatusTime" Text="—" FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="LOCATION" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" FontSize="11" />
                    <TextBlock x:Name="StatusLocation" Text="—" FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="UNIT" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" FontSize="11" />
                    <TextBlock x:Name="StatusUnit" Text="—" FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="CALLOUTS" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" FontSize="11" />
                    <TextBlock x:Name="StatusCallouts" Text="—" FontFamily="Consolas" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="0,1,0,0" Padding="8" MaxHeight="140">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="CAD MESSAGE LOG" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="11" Foreground="{StaticResource CadMuted}" />
                <ListBox x:Name="MessageLog" Style="{StaticResource CadListBox}" FontFamily="Consolas" FontSize="11" />
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource CadStatusBar}" BorderBrush="{StaticResource CadBorder}" BorderThickness="0,0,1,0" Padding="4">
                <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource CadText}"
                         SelectionChanged="NavList_OnSelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource CadBg}" Padding="0">
                <ContentControl x:Name="ContentHost" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
