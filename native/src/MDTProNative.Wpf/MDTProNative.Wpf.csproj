<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\MDTProNative.Client\MDTProNative.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3967.48" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Version>0.9.9.6</Version>
    <!-- Different from LSPDFR plugin MDTPro.dll — same filename there would break RPH. -->
    <AssemblyName>MDTProNative</AssemblyName>
    <AssemblyTitle>MDT Pro</AssemblyTitle>
    <Product>MDT Pro</Product>
    <ApplicationIcon>Assets\MdtProApp.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\..\..\MDTPro\img\favicon.png">
      <Link>Assets\MdtProLogo.png</Link>
    </Resource>
    <Content Include="..\..\slick-notification.mp3">
      <Link>slick-notification.mp3</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\courtcase-update.mp3">
      <Link>courtcase-update.mp3</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\savebutton.mp3">
      <Link>savebutton.mp3</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\newcallout.mp3">
      <Link>newcallout.mp3</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
