<Application x:Class="MDTProNative.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <BitmapImage x:Key="MdtProLogoImage"
                         UriSource="pack://application:,,,/MDTProNative.Wpf;component/Assets/MdtProLogo.png"
