<Window x:Class="MDTProNative.Wpf.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MDTProNative.Wpf.Views"
        Title="MDC — Settings"
        Icon="{StaticResource MdtProLogoImage}"
        Width="720" Height="560"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CadBg}"
        Foreground="{StaticResource CadText}">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" Text="SETTINGS" FontFamily="{StaticResource CadFontMono}" FontSize="13" Foreground="{StaticResource CadAccent}" Margin="0,0,0,10" />
        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Button Content="Close" Style="{StaticResource CadButton}" HorizontalAlignment="Right" Click="Close_Click" MinWidth="100" />
        </StackPanel>
        <TabControl Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}">
            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                    <StackPanel>
                        <TextBlock x:Name="VersionText" TextWrapping="Wrap" Margin="0,0,0,16" FontFamily="{StaticResource CadFontMono}" FontSize="12" />
                        <TextBlock Text="Open in external browser" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" Margin="0,0,0,10"
                                   Text="Use this if you prefer the customization page in Chrome or Edge instead of the embedded view." />
                        <Button x:Name="OpenCustomizationBrowserBtn" Content="Open Config &amp; Plugins in browser" Style="{StaticResource CadAccentButton}"
                                HorizontalAlignment="Left" Click="OpenCustomizationBrowser_Click" Margin="0,0,0,8" />
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11" Margin="0,0,0,8"
                                   Text="Full web desktop includes plugin-hosted windows and the same shortcuts as opening the MDT in Chrome/Edge." />
                        <Button x:Name="OpenWebHomeBrowserBtn" Content="Open web home (full desktop) in browser" Style="{StaticResource CadButton}"
                                HorizontalAlignment="Left" Click="OpenWebHomeBrowser_Click" Margin="0,0,0,16" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Config &amp; plugins">
                <DockPanel Margin="0,8,0,0">
                    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11" Margin="0,0,0,8"
                               Text="Same customization editor as the browser MDT (agency settings, plugin toggles). Requires an active connection." />
                    <views:MdtWebPageView x:Name="CustomizationHost" PageName="customization" ShowToolbar="True" />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
