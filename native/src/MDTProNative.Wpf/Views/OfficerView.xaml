<UserControl x:Class="MDTProNative.Wpf.Views.OfficerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Load" Style="{StaticResource CadButton}" Click="Load_Click" Margin="0,0,8,0" />
            <Button Content="Save to MDT" Style="{StaticResource CadAccentButton}" Click="Save_Click" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="First" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,8" />
            <TextBox x:Name="First" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBox}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1" Text="Last" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,8" />
            <TextBox x:Name="Last" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBox}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="2" Text="Rank" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,8" />
            <TextBox x:Name="Rank" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBox}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="3" Text="Call sign" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,8" />
            <TextBox x:Name="CallSign" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadTextBox}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="4" Text="Agency" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,8" />
            <TextBox x:Name="Agency" Grid.Row="4" Grid.Column="1" Style="{StaticResource CadTextBox}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="5" Text="Badge #" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" />
            <TextBox x:Name="Badge" Grid.Row="5" Grid.Column="1" Style="{StaticResource CadTextBox}" />
        </Grid>
    </DockPanel>
</UserControl>
