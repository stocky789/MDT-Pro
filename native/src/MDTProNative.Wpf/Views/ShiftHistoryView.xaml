<UserControl x:Class="MDTProNative.Wpf.Views.ShiftHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CadSectionBorder}" Padding="14" Margin="0,0,0,0">
        <DockPanel LastChildFill="True">
            <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,10">
                <Button x:Name="RefreshShiftsBtn" DockPanel.Dock="Right" Content="Refresh history" Style="{StaticResource CadButton}" Margin="8,0,0,0" Padding="10,4" />
                <TextBlock Text="SHIFT HISTORY" Style="{StaticResource CadSectionTitle}" VerticalAlignment="Center" />
            </DockPanel>
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11" Margin="0,0,0,10"
                       Text="Past shifts (newest first) and report IDs linked to each shift." />
            <Grid MinHeight="220">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" MinWidth="200" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" MinWidth="200" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="SHIFTS" Style="{StaticResource CadLabelMuted}" Margin="0,0,0,6" />
                    <ListBox x:Name="ShiftList"
                             Style="{StaticResource CadListBox}"
                             ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"
                             SelectionChanged="ShiftList_OnSelectionChanged" />
                </DockPanel>
                <Border Grid.Column="2" Style="{StaticResource CadModuleChromeBorder}" Padding="12">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="REPORT IDS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                            <TextBlock x:Name="ShiftDetailText"
                                       TextWrapping="Wrap"
                                       FontFamily="{StaticResource CadFontMono}"
                                       FontSize="11"
                                       Foreground="{StaticResource CadText}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
