<UserControl x:Class="MDTProNative.Wpf.Views.NativeCourtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cad="clr-namespace:MDTProNative.Wpf.Views.Controls">
    <Grid Margin="0,8,0,0">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource CadModuleChromeBorder}" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="160" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilterBox"
                         Grid.Column="0"
                         Style="{StaticResource CadTextBoxCadField}"
                         VerticalContentAlignment="Center"
                         ToolTip="Filter by case number, defendant, or report ID" />
                <ComboBox x:Name="StatusFilter"
                          Grid.Column="2"
                          Style="{StaticResource CadComboBox}" />
                <ComboBox x:Name="SortFilter"
                          Grid.Column="4"
                          Style="{StaticResource CadComboBox}"
                          ToolTip="Match browser court list ordering" />
                <Button x:Name="RefreshBtn"
                        Grid.Column="6"
                        Content="REFRESH DOCKET"
                        Style="{StaticResource CadPrimaryActionButton}" />
            </Grid>
        </Border>
        <TextBlock DockPanel.Dock="Top"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource CadMuted}"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Text="Docket matches the browser Court module: expand a case for timeline, scoring, trial model, evidence breakdown, attached reports, and disposition text. Pending cases: save plea/notes, dismiss, attach/detach evidence, or auto-resolve. Use defendant / report links to jump to Person or Reports." />
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="CaseStack" />
        </ScrollViewer>
    </DockPanel>
    <cad:MdtBusyOverlay x:Name="DocketBusy"
                        Panel.ZIndex="60"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch" />
    </Grid>
</UserControl>
