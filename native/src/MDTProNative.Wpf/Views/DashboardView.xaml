<UserControl x:Class="MDTProNative.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="1" CornerRadius="2" Padding="8">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="ACTIVE CALLOUTS" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="11" Foreground="{StaticResource CadMuted}" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Button Content="Set GPS waypoint" Style="{StaticResource CadAccentButton}" Click="SetWaypoint_Click" Margin="0,0,0,6" />
                    <TextBlock Text="Uses active callout coords or last known (plugin)." Style="{StaticResource CadLabelMuted}" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
                <ListBox x:Name="CalloutList" Style="{StaticResource CadListBox}" FontFamily="Consolas" FontSize="12" SelectionChanged="CalloutList_OnSelectionChanged" />
            </DockPanel>
        </Border>
        <Border Grid.Column="2" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="1" CornerRadius="2" Padding="10">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="DETAIL" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="11" Foreground="{StaticResource CadMuted}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DetailText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource CadText}" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
