<UserControl x:Class="MDTProNative.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="DashboardSidebarColumn" Width="280" MinWidth="200" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CadSectionBorder}" Padding="10">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="ACTIVE CALLOUTS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                    <Button Content="SET GPS WAYPOINT" Style="{StaticResource CadAccentButton}" Click="SetWaypoint_Click" Margin="0,0,0,6" />
                    <TextBlock Text="Uses selected callout coordinates when the plugin provides them; otherwise the default in-game target."
                               Style="{StaticResource CadLabelMuted}" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
                <ListBox x:Name="CalloutList" Style="{StaticResource CadListBox}" FontFamily="{StaticResource CadFontMono}" FontSize="12" SelectionChanged="CalloutList_OnSelectionChanged" />
            </DockPanel>
        </Border>
        <GridSplitter x:Name="DashboardSplitter"
                      Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      Background="{StaticResource CadBorder}" />
        <Border Grid.Column="2" Style="{StaticResource CadSectionBorder}" Padding="10">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="CALLOUT DETAIL" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11" Margin="0,0,0,8"
                           Text="Structured readout for the selected call. Accept, en route, and scene actions stay in-game (no API)." />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DetailText" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource CadText}" />
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
