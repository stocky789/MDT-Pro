<UserControl x:Class="MDTProNative.Wpf.Views.PersonSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CadModuleChromeBorder}" Padding="10" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SearchBtn" Content="SEARCH" Style="{StaticResource CadPrimaryActionButton}" Margin="8,0,0,0" />
                    <Button x:Name="ContextPedBtn" Content="CONTEXT PED" Style="{StaticResource CadRailOutlineButton}" Margin="8,0,0,0" />
                    <Button x:Name="RefreshSidebarBtn" Content="REFRESH LISTS" Style="{StaticResource CadRailOutlineButton}" Margin="8,0,0,0" />
                </StackPanel>
                <TextBox x:Name="QueryBox"
                         Style="{StaticResource CadTextBoxCadField}"
                         VerticalContentAlignment="Center"
                         ToolTip="Enter full or partial name, or use Context ped for the subject in front of you" />
            </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="RECENT IDs" Style="{StaticResource CadSectionTitle}" />
                <TextBlock Grid.Row="0"
                           x:Name="RecentEmptyHint"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource CadMuted}"
                           FontSize="11"
                           Margin="0,22,0,0"
                           Text="No recent identifications. Run IDs in-game to populate."
                           Visibility="Collapsed" />
                <ListBox x:Name="RecentList"
                         Grid.Row="1"
                         Style="{StaticResource CadListBox}"
                         ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"
                         Margin="0,4,0,10" />
                <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,0,0,4">
                    <Button x:Name="ClearPedHistoryBtn"
                            DockPanel.Dock="Right"
                            Content="CLEAR HISTORY"
                            Style="{StaticResource CadRailOutlineButton}"
                            VerticalAlignment="Center"
                            Padding="8,2" />
                    <TextBlock Text="RECENT SEARCHES" Style="{StaticResource CadSectionTitle}" VerticalAlignment="Center" />
                </DockPanel>
                <ListBox x:Name="HistoryList"
                         Grid.Row="3"
                         Style="{StaticResource CadListBox}"
                         ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"
                         Margin="0,4,0,0" />
            </Grid>
            <Border Grid.Column="2" Style="{StaticResource CadModuleChromeBorder}" Padding="12">
                <DockPanel LastChildFill="True">
                    <Expander x:Name="PedJsonExpander"
                              DockPanel.Dock="Bottom"
                              Margin="0,12,0,0"
                              Header="EDIT PED RECORD (JSON)"
                              IsExpanded="False">
                        <DockPanel Margin="0,8,0,0">
                            <Button x:Name="SavePedBtn"
                                    DockPanel.Dock="Bottom"
                                    Content="SAVE PED FROM JSON (REQUIRES SUBJECT IN WORLD)"
                                    Style="{StaticResource CadPrimaryActionButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" />
                            <TextBox x:Name="PedJsonEditor"
                                     MinHeight="120"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     TextWrapping="Wrap"
                                     Foreground="{StaticResource CadText}"
                                     Background="{StaticResource CadElevated}"
                                     BorderBrush="{StaticResource CadAccentDim}"
                                     Padding="8" />
                        </DockPanel>
                    </Expander>
                    <TabControl x:Name="PersonDetailTabs"
                                Background="{StaticResource CadPanel}"
                                BorderBrush="{StaticResource CadAccentDim}">
                        <TabControl.Resources>
                            <Style TargetType="TabItem" BasedOn="{StaticResource CadSubTabItem}" />
                        </TabControl.Resources>
                        <TabItem Header="SUMMARY">
                            <ScrollViewer x:Name="DetailScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                                <StackPanel x:Name="DetailPanel">
                                    <TextBlock x:Name="DetailPlaceholder"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource CadMuted}"
                                               FontSize="12"
                                               Text="Search for a person or pick a name from the list. Results use the same data as the in-game MDT (native layout only)." />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="EDIT FORM">
                            <DockPanel Margin="0,8,0,0" LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource CadMuted}"
                                           FontSize="11"
                                           Margin="0,0,0,8"
                                           Text="Structured fields for the same ped JSON. Citations, arrests, and ID history lists are not edited here — use the JSON tab for those arrays." />
                                <Button x:Name="SavePedFormBtn"
                                        DockPanel.Dock="Bottom"
                                        Content="SAVE PED FROM FORM (REQUIRES SUBJECT IN WORLD)"
                                        Style="{StaticResource CadPrimaryActionButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <TextBlock Text="IDENTITY" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormName" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="First" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormFirst" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormLast" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Model" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormModel" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="DOB (ISO)" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormDob" Grid.Row="4" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Gender" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormGender" Grid.Row="5" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Address" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormAddress" Grid.Row="6" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                        </Grid>
                                        <TextBlock Text="STATUS FLAGS" Style="{StaticResource CadSectionTitle}" Margin="0,8,0,8" />
                                        <WrapPanel Margin="0,0,0,12">
                                            <CheckBox x:Name="PedFormWanted" Content="Wanted" Margin="0,0,16,8" Foreground="{StaticResource CadText}" />
                                            <CheckBox x:Name="PedFormProbation" Content="Probation" Margin="0,0,16,8" Foreground="{StaticResource CadText}" />
                                            <CheckBox x:Name="PedFormParole" Content="Parole" Margin="0,0,16,8" Foreground="{StaticResource CadText}" />
                                            <CheckBox x:Name="PedFormGang" Content="Gang" Margin="0,0,16,8" Foreground="{StaticResource CadText}" />
                                            <CheckBox x:Name="PedFormDeceased" Content="Deceased" Margin="0,0,16,8" Foreground="{StaticResource CadText}" />
                                        </WrapPanel>
                                        <TextBlock Text="NOTES &amp; COUNTS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Warrant text" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Top" />
                                            <TextBox x:Name="PedFormWarrant" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" AcceptsReturn="True" MinHeight="44" TextWrapping="Wrap" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Advisory" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Top" />
                                            <TextBox x:Name="PedFormAdvisory" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" AcceptsReturn="True" MinHeight="44" TextWrapping="Wrap" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Times stopped" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" VerticalAlignment="Center" />
                                            <TextBox x:Name="PedFormTimesStopped" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                        </Grid>
                                        <TextBlock Text="LICENSES &amp; PERMITS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Driver status" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormLicStatus" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="License exp." Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormLicExp" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Weapon permit" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormWpStatus" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Weapon type" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormWpType" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Weapon exp." Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormWpExp" Grid.Row="4" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Hunting" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormHuntStatus" Grid.Row="5" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Hunting exp." Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormHuntExp" Grid.Row="6" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Fishing" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormFishStatus" Grid.Row="7" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Fishing exp." Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormFishExp" Grid.Row="8" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                        </Grid>
                                        <TextBlock Text="OTHER" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Incarcerated until" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormIncarcerated" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Deceased at" Style="{StaticResource CadFieldLabel}" Margin="0,4,8,4" />
                                            <TextBox x:Name="PedFormDeceasedAt" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,2,0,2" />
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
