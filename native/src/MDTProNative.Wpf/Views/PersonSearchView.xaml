<UserControl x:Class="MDTProNative.Wpf.Views.PersonSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Name" Style="{StaticResource CadLabelMuted}" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBox x:Name="NameBox" Width="280" Style="{StaticResource CadTextBox}" VerticalAlignment="Center" />
            <Button Content="Search" Style="{StaticResource CadAccentButton}" Margin="8,0,0,0" Click="Search_Click" />
            <Button Content="Context ped" Style="{StaticResource CadButton}" Margin="8,0,0,0" Click="Context_Click" />
            <Button Content="Refresh recent IDs" Style="{StaticResource CadButton}" Margin="8,0,0,0" Click="Recent_Click" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="1" Padding="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="RECENT IDs" FontSize="11" Foreground="{StaticResource CadMuted}" Margin="0,0,0,6" />
                    <ListBox x:Name="RecentList" Style="{StaticResource CadListBox}" FontFamily="Consolas" FontSize="11" MouseDoubleClick="RecentList_MouseDoubleClick" />
                </DockPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadBorder}" BorderThickness="1" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="ResultBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource CadText}" />
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
