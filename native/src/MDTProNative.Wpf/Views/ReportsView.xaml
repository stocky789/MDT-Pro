<UserControl x:Class="MDTProNative.Wpf.Views.ReportsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="8" LastChildFill="True">

        <Border DockPanel.Dock="Top" Style="{StaticResource CadModuleChromeBorder}" Padding="10" Margin="0,0,0,8">

            <DockPanel LastChildFill="True">

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">

                    <Button x:Name="RefreshBtn" Content="REFRESH LIST" Style="{StaticResource CadRailOutlineButton}" Margin="8,0,0,0" />

                    <Button x:Name="NewBtn" Content="NEW REPORT" Style="{StaticResource CadRailOutlineButton}" Margin="8,0,0,0" />

                    <Button x:Name="SaveBtn" Content="SAVE TO MDT" Style="{StaticResource CadPrimaryActionButton}" Margin="8,0,0,0" />

                </StackPanel>

                <WrapPanel VerticalAlignment="Center">

                    <TextBlock Text="TYPE" Style="{StaticResource CadFieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />

                    <ComboBox x:Name="CategoryCombo"

                              MinWidth="260"

                              Style="{StaticResource CadComboBox}"

                              VerticalAlignment="Center"

                              DisplayMemberPath="Label"

                              SelectedValuePath="TypeKey" />

                </WrapPanel>

            </DockPanel>

        </Border>

        <TextBlock DockPanel.Dock="Top"

                   TextWrapping="Wrap"

                   Foreground="{StaticResource CadMuted}"

                   FontSize="11"

                   Margin="0,0,0,8"

                   Text="Stay ONLINE. Choose TYPE → NEW REPORT → edit FORM (or JSON) → SAVE TO MDT. Select a list row to load an existing report." />

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="280" MinWidth="220" />

                <ColumnDefinition Width="10" />

                <ColumnDefinition Width="*" MinWidth="320" />

            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" LastChildFill="True">

                <TextBlock DockPanel.Dock="Top" Text="SAVED REPORTS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,6" />

                <ListBox x:Name="ReportList"

                         Style="{StaticResource CadListBox}"

                         ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"

                         DisplayMemberPath="Display" />

            </DockPanel>

            <Border Grid.Column="2" Style="{StaticResource CadModuleChromeBorder}" Padding="10">

                <DockPanel LastChildFill="True">

                    <TextBlock x:Name="EditorHint"

                               DockPanel.Dock="Top"

                               TextWrapping="Wrap"

                               Foreground="{StaticResource CadMuted}"

                               FontSize="11"

                               Margin="0,0,0,8"

                               Text="Select a report or create a new draft." />

                    <TabControl x:Name="ReportEditorTabs"

                                Background="{StaticResource CadPanel}"

                                BorderBrush="{StaticResource CadAccentDim}"

                                Margin="0,0,0,0">

                        <TabControl.Resources>

                            <Style TargetType="TabItem" BasedOn="{StaticResource CadSubTabItem}" />

                        </TabControl.Resources>

                        <TabItem Header="FORM">

                            <ScrollViewer VerticalScrollBarVisibility="Auto"

                                          HorizontalScrollBarVisibility="Disabled"

                                          Margin="0,8,0,0"

                                          MinHeight="240">

                                <ContentControl x:Name="FormHost" MinHeight="200" />

                            </ScrollViewer>

                        </TabItem>

                        <TabItem Header="JSON">

                            <TextBox x:Name="JsonEditor"

                                     Margin="0,8,0,0"

                                     AcceptsReturn="True"

                                     AcceptsTab="True"

                                     VerticalScrollBarVisibility="Auto"

                                     HorizontalScrollBarVisibility="Auto"

                                     TextWrapping="Wrap"

                                     FontFamily="Consolas"

                                     FontSize="12"

                                     Foreground="{StaticResource CadText}"

                                     Background="{StaticResource CadElevated}"

                                     BorderBrush="{StaticResource CadAccentDim}"

                                     Padding="8" />

                        </TabItem>

                    </TabControl>

                </DockPanel>

            </Border>

        </Grid>

    </DockPanel>

</UserControl>

