<UserControl x:Class="MDTProNative.Wpf.Views.Reports.Forms.IncidentReportForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:reports="clr-namespace:MDTProNative.Wpf.Views.Reports">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="ReportEditorToolbar" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ExportPdfBtn" Content="EXPORT PDF…" Style="{StaticResource CadRailOutlineButton}" Padding="12,6" Margin="0,0,8,0" />
            <TextBlock x:Name="BrandingTemplateHint"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource CadMuted}"
                       FontSize="11"
                       Text="" />
        </StackPanel>

        <ScrollViewer x:Name="DocumentBodyScroll"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border x:Name="DocumentPrintRoot"
                    Background="{StaticResource ReportDocPaperBrush}"
                    BorderBrush="{StaticResource ReportDocInkBrush}"
                    BorderThickness="1"
                    Padding="18"
                    MaxWidth="920"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <reports:ReportDocumentHeader x:Name="DocHeader" />

                    <TextBlock Text="Case / report identification" Style="{StaticResource ReportDocSectionTitle}" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Report ID" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Short year" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="ShortYearBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Date / time" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" VerticalAlignment="Top" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <DatePicker x:Name="TsDatePicker" Width="160" Margin="0,0,8,0" FontSize="11" />
                            <TextBox x:Name="TsTimeBox"
                                     Width="120"
                                     ToolTip="Time (e.g. 14:30:00 or 14:30)"
                                     Style="{StaticResource ReportDocTextBox}" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Status" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <ComboBox x:Name="StatusCombo"
                                  Grid.Row="3"
                                  Grid.Column="1"
                                  Style="{StaticResource ReportDocCombo}"
                                  Margin="0,0,0,6" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Narrative notes" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,0" VerticalAlignment="Top" />
                        <TextBox x:Name="NotesBox"
                                 Grid.Row="4"
                                 Grid.Column="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource ReportDocTextBox}" />
                    </Grid>

                    <TextBlock Text="Reporting officer" Style="{StaticResource ReportDocSectionTitle}" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="First name" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfFirstBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Last name" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfLastBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Rank" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfRankBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Call sign" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfCallBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Agency" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfAgencyBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Badge #" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,0" />
                        <TextBox x:Name="OfBadgeBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" />
                    </Grid>

                    <TextBlock Text="Location" Style="{StaticResource ReportDocSectionTitle}" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Area" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocAreaBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Street" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocStreetBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="County" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocCountyBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Postal" Style="{StaticResource ReportDocLabel}" Margin="0,0,8,0" />
                        <TextBox x:Name="LocPostalBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource ReportDocTextBox}" />
                    </Grid>

                    <TextBlock Text="Persons involved" Style="{StaticResource ReportDocSectionTitle}" />
                    <TextBlock Text="Offender / suspect (one name per line)" Style="{StaticResource ReportDocLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="OffenderNamesBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ReportDocTextBox}"
                             Margin="0,0,0,10" />
                    <TextBlock Text="Witnesses (one per line)" Style="{StaticResource ReportDocLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="WitnessNamesBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ReportDocTextBox}"
                             Margin="0,0,0,8" />

                    <Button x:Name="ClearFormBtn"
                            Content="CLEAR FORM"
                            HorizontalAlignment="Left"
                            Style="{StaticResource CadRailOutlineButton}"
                            Padding="12,6"
                            Margin="0,0,0,8" />

                    <TextBlock x:Name="BrandingFooter"
                               TextWrapping="Wrap"
                               FontSize="10"
                               Foreground="#444"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
