<UserControl x:Class="MDTProNative.Wpf.Views.Reports.Forms.ImpoundReportForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:reports="clr-namespace:MDTProNative.Wpf.Views.Reports">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="ReportEditorToolbar" Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ExportPdfBtn" Content="EXPORT PDF…" Style="{StaticResource CadRailOutlineButton}" Padding="12,6" Margin="0,0,8,0" />
                <TextBlock x:Name="BrandingTemplateHint"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource CadText}"
                           FontSize="11"
                           Text="" />
            </StackPanel>
            <reports:ReportNearbyVehicleBar x:Name="NearbyVehicleBar" Margin="0,8,0,0" />
        </StackPanel>

        <ScrollViewer x:Name="DocumentBodyScroll"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border x:Name="DocumentPrintRoot"
                    TextElement.Foreground="{StaticResource ReportDocInkBrush}"
                    Background="{StaticResource ReportDocPaperBrush}"
                    BorderBrush="{StaticResource ReportDocInkBrush}"
                    BorderThickness="1"
                    Padding="18"
                    MaxWidth="920"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <reports:ReportDocumentHeader x:Name="DocHeader" />

                    <TextBlock Text="Base report" Style="{StaticResource ReportDocSectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Report ID" Style="{StaticResource ReportDocLabel}" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IdBox" Grid.Column="0" Style="{StaticResource ReportDocTextBox}" Margin="0,0,8,0" />
                                <Button x:Name="CopyReportIdBtn"
                                        Grid.Column="1"
                                        Content="COPY"
                                        Style="{StaticResource CadRailOutlineButton}"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy report ID to clipboard" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Short year" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="ShortYearBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                    </UniformGrid>
                    <TextBlock Text="Timestamp" Style="{StaticResource ReportDocLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="TimeStampBox"
                             Style="{StaticResource ReportDocTextBox}"
                             Margin="0,0,0,8"
                             ToolTip="dd/MM/yyyy HH:mm (local), or ISO" />
                    <TextBlock Text="Status" Style="{StaticResource ReportDocLabel}" Margin="0,0,0,4" />
                    <ComboBox x:Name="StatusCombo" Style="{StaticResource ReportDocCombo}" Margin="0,0,0,8" />
                    <TextBlock Text="Notes" Style="{StaticResource ReportDocLabel}" Margin="0,4,0,2" />
                    <TextBox x:Name="NotesBox"
                             MinHeight="56"
                             AcceptsReturn="True"
                             Style="{StaticResource ReportDocTextBox}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <TextBlock Text="Officer" Style="{StaticResource ReportDocSectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="First name" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerFirstBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Last name" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerLastBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Rank" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerRankBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Call sign" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerCallSignBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Agency" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerAgencyBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Badge #" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OfficerBadgeBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Location" Style="{StaticResource ReportDocSectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Area" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="LocAreaBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Street" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="LocStreetBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="County" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="LocCountyBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Postal" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="LocPostalBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Impound / tow" Style="{StaticResource ReportDocSectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="License plate" Style="{StaticResource ReportDocLabel}" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="LicensePlateBox" Grid.Column="0" Style="{StaticResource ReportDocTextBox}" Margin="0,0,8,0" />
                                <Button x:Name="CopyLicensePlateBtn"
                                        Grid.Column="1"
                                        Content="COPY"
                                        Style="{StaticResource CadRailOutlineButton}"
                                        Padding="10,4"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy plate to clipboard" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Vehicle model" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="VehicleModelBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Owner" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="OwnerBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Person at fault" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="PersonAtFaultNameBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="VIN" Style="{StaticResource ReportDocLabel}" />
                            <TextBox x:Name="VinBox" Style="{StaticResource ReportDocTextBox}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Impound reason" Style="{StaticResource ReportDocLabel}" />
                            <ComboBox x:Name="ImpoundReasonCombo" Style="{StaticResource ReportDocCombo}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,8,6">
                            <TextBlock Text="Tow company" Style="{StaticResource ReportDocLabel}" />
                            <ComboBox x:Name="TowCompanyCombo" Style="{StaticResource ReportDocCombo}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Impound lot" Style="{StaticResource ReportDocLabel}" />
                            <ComboBox x:Name="ImpoundLotCombo" Style="{StaticResource ReportDocCombo}" Margin="0,4,0,0" />
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock x:Name="BrandingFooter"
                               TextWrapping="Wrap"
                               FontSize="10"
                               Foreground="{StaticResource ReportDocInkBrush}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
