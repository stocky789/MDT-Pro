<UserControl x:Class="MDTProNative.Wpf.Views.Reports.Forms.CitationReportForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <Border Style="{StaticResource CadModuleChromeBorder}" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="BASE" Style="{StaticResource CadSectionTitle}" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="SHORT YEAR" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="ShortYearBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="TIME STAMP" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" VerticalAlignment="Top" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <DatePicker x:Name="TsDatePicker" Width="160" Margin="0,0,8,0" />
                            <TextBox x:Name="TsTimeBox"
                                     Width="120"
                                     ToolTip="Time (e.g. 14:30:00 or 14:30)"
                                     Style="{StaticResource CadTextBoxCadField}" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="STATUS" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <ComboBox x:Name="StatusCombo"
                                  Grid.Row="3"
                                  Grid.Column="1"
                                  Style="{StaticResource CadComboBox}"
                                  Margin="0,0,0,6" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="NOTES" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,0" VerticalAlignment="Top" />
                        <TextBox x:Name="NotesBox"
                                 Grid.Row="4"
                                 Grid.Column="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource CadTextBoxCadField}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CadModuleChromeBorder}" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="OFFICER INFORMATION" Style="{StaticResource CadSectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="FIRST" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfFirstBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="LAST" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfLastBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="RANK" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfRankBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="CALL SIGN" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfCallBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="AGENCY" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="OfAgencyBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="BADGE #" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,0" />
                        <TextBox x:Name="OfBadgeBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CadModuleChromeBorder}" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="LOCATION" Style="{StaticResource CadSectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AREA" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocAreaBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="STREET" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocStreetBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="COUNTY" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,6" />
                        <TextBox x:Name="LocCountyBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,6" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="POSTAL" Style="{StaticResource CadFieldLabel}" Margin="0,0,8,0" />
                        <TextBox x:Name="LocPostalBox" Grid.Row="3" Grid.Column="1" Style="{StaticResource CadTextBoxCadField}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CadModuleChromeBorder}" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="CITATION" Style="{StaticResource CadSectionTitle}" />
                    <TextBlock Text="OFFENDER PED NAME" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="OffenderPedBox" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,10" />
                    <TextBlock Text="OFFENDER VEHICLE PLATE" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="OffenderPlateBox" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,10" />
                    <TextBlock Text="COURT CASE # (optional)" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="CourtCaseBox" Style="{StaticResource CadTextBoxCadField}" Margin="0,0,0,10" />
                    <TextBlock Text="CHARGES (JSON array or empty)" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                    <TextBox x:Name="ChargesBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             MinHeight="140"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource CadTextBoxCadField}" />
                </StackPanel>
            </Border>

            <Button x:Name="ClearFormBtn"
                    Content="CLEAR FORM"
                    HorizontalAlignment="Left"
                    Style="{StaticResource CadPrimaryActionButton}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
