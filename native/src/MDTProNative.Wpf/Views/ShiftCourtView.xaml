<UserControl x:Class="MDTProNative.Wpf.Views.ShiftCourtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MDTProNative.Wpf.Views">
    <DockPanel Margin="8">
        <Border DockPanel.Dock="Top" Style="{StaticResource CadModuleChromeBorder}" Padding="10" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <Button x:Name="RefreshShiftsBtn" DockPanel.Dock="Right" Content="REFRESH SHIFTS" Style="{StaticResource CadPrimaryActionButton}" Margin="8,0,0,0" />
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11"
                           Text="Shift: browse shifts and linked report IDs. Court: native docket with pending-case actions (outcomes, attach/detach reports, auto-resolve)." />
            </DockPanel>
        </Border>
        <TabControl x:Name="Tabs" Background="{StaticResource CadPanel}" BorderBrush="{StaticResource CadAccentDim}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource CadSubTabItem}" />
            </TabControl.Resources>
            <TabItem Header="SHIFT HISTORY">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" MinWidth="240" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" MinWidth="280" />
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="SHIFTS (NEWEST FIRST)" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,6" />
                        <ListBox x:Name="ShiftList"
                                 Style="{StaticResource CadListBox}"
                                 ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"
                                 SelectionChanged="ShiftList_OnSelectionChanged" />
                    </DockPanel>
                    <Border Grid.Column="2" Style="{StaticResource CadModuleChromeBorder}" Padding="12">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="SHIFT REPORT IDS" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ShiftDetailText"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource CadFontMono}"
                                           FontSize="11"
                                           Foreground="{StaticResource CadText}" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="COURT">
                <views:NativeCourtView x:Name="CourtNative" Margin="0,8,0,0" />
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
