<UserControl x:Class="MDTProNative.Wpf.Views.MdtWebPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <DockPanel>
        <StackPanel x:Name="ToolbarRow" DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ReloadBtn" Content="Reload page" Style="{StaticResource CadButton}" Padding="12,6" Click="Reload_Click" />
        </StackPanel>
        <Grid>
            <wv2:WebView2 x:Name="Web" />
            <Border x:Name="ErrorPanel" Visibility="Collapsed" Background="#CC0A0F16" BorderBrush="{StaticResource CadBorder}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520" Margin="24">
                    <TextBlock Text="PAGE UNAVAILABLE" FontFamily="{StaticResource CadFontMono}" FontSize="14" Foreground="{StaticResource CadUrgent}" Margin="0,0,0,8" />
                    <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="{StaticResource CadText}" FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
