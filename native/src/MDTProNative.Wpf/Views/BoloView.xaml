<UserControl x:Class="MDTProNative.Wpf.Views.BoloView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cad="clr-namespace:MDTProNative.Wpf.Views.Controls">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CadModuleChromeBorder}" Padding="10" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="RefreshBtn" Content="REFRESH" Style="{StaticResource CadPrimaryActionButton}" Margin="8,0,0,0" />
                    <Button x:Name="AddBoloBtn" Content="ADD BOLO" Style="{StaticResource CadAccentButton}" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CadMuted}" FontSize="11"
                           Text="Active vehicle BOLOs from the live database. Add/remove requires the vehicle in the world when the plugin allows modification." />
            </DockPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CadSectionBorder}" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLATE" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewPlateBox" Style="{StaticResource CadTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="REASON" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewReasonBox" Style="{StaticResource CadTextBox}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <TextBlock Text="MODEL (opt.)" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewModelBox" Style="{StaticResource CadTextBox}" MinWidth="140" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ISSUED BY" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                        <TextBox x:Name="IssuedByBox" Style="{StaticResource CadTextBox}" Text="MDC" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="EXPIRES (local)" Style="{StaticResource CadFieldLabel}" Margin="0,0,0,4" />
                        <DatePicker x:Name="ExpiresPicker" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BoloSidebarColumn" Width="320" MinWidth="260" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="VEHICLES WITH ACTIVE BOLO" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,6" />
                <ListBox x:Name="VehicleList"
                         Style="{StaticResource CadListBox}"
                         ItemContainerStyle="{StaticResource CadSidebarListBoxItem}"
                         SelectionChanged="VehicleList_OnSelectionChanged" />
            </DockPanel>
            <GridSplitter x:Name="BoloSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="{StaticResource CadBorder}" />
            <Border Grid.Column="2" Style="{StaticResource CadModuleChromeBorder}" Padding="12">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="BOLO LINES" Style="{StaticResource CadSectionTitle}" Margin="0,0,0,8" />
                    <ItemsControl x:Name="BoloLinesPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
        <cad:MdtBusyOverlay x:Name="ModuleBusy"
                            Grid.RowSpan="3"
                            Panel.ZIndex="100"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch" />
    </Grid>
</UserControl>
